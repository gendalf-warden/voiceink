<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access for voice dictation (also declared in Info.plist) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Required to load bundled whisper-server, llama-server and their dylibs
         that are not signed by Apple -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required for whisper.cpp / GGML JIT-style code paths and Metal compute -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
